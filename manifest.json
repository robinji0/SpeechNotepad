{
  "manifest_version": 3,
  "name": "Speech Notepad (Insert at Cursor)",
  "version": "1.0",
  "description": "A smart speech-to-text extension that inserts text exactly at your cursor position without overwriting.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Speech Notepad"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Open Speech Notepad in Chrome"
    },
    "open_global_window": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Speech Notepad in a global window (cross-application)",
      "global": true
    }
  }
}
